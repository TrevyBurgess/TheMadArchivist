<UserControl
    x:Name="ControlRoot"
    x:Class="CyberFeedForward.TheMadArchivist.Views.Controls.NamedIconControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid
        x:Name="RootGrid"
        ColumnDefinitions="Auto,*"
        ColumnSpacing="8">
        <SymbolIcon
            x:Name="NamedIcon"
            Symbol="{Binding ElementName=ControlRoot, Path=ViewModel.IconSymbol}"
            VerticalAlignment="Center" />

        <TextBlock
            x:Name="NamedText"
            Grid.Column="1"
            Text="{Binding ElementName=ControlRoot, Path=ViewModel.Name}"
            VerticalAlignment="Center"
            TextTrimming="CharacterEllipsis" />
    </Grid>
</UserControl>
