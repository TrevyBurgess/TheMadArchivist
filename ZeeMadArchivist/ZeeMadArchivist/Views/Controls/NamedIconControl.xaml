<UserControl
    x:Name="ControlRoot"
    x:Class="CyberFeedForward.TheMadArchivist.Views.Controls.NamedIconControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel
        x:Name="RootPanel"
        Spacing="12">

        <Grid
            x:Name="HeaderGrid"
            ColumnDefinitions="Auto,*"
            ColumnSpacing="8">
            <SymbolIcon
                x:Name="NamedIcon"
                Symbol="{Binding ElementName=ControlRoot, Path=ViewModel.IconSymbol}"
                VerticalAlignment="Center" />

            <TextBlock
                x:Name="NamedText"
                Grid.Column="1"
                Text="{Binding ElementName=ControlRoot, Path=ViewModel.Name}"
                VerticalAlignment="Center"
                TextTrimming="CharacterEllipsis" />
        </Grid>

        <ListView
            x:Name="ItemsTable"
            ItemsSource="{Binding ElementName=ControlRoot, Path=ViewModel.Items}"
            MinHeight="160">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid
                        x:Name="TableRowGrid"
                        ColumnDefinitions="Auto,*"
                        ColumnSpacing="8">
                        <Image
                            x:Name="RowIconImage"
                            Width="20"
                            Height="20"
                            VerticalAlignment="Center"
                            Source="{Binding IconImage}"
                        />

                        <TextBox
                            Background="AliceBlue"
                            x:Name="RowTextBox"
                            Grid.Column="1"
                            Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            VerticalAlignment="Center"
                        />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Button
            x:Name="SaveButton"
            Content="Save"
            HorizontalAlignment="Left"
            IsEnabled="{Binding ElementName=ControlRoot, Path=ViewModel.IsSaveEnabled}"
            Click="SaveButton_OnClick" />
    </StackPanel>
</UserControl>
