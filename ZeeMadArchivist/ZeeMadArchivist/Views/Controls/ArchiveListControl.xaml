<UserControl
    x:Name="ControlRoot"
    x:Class="CyberFeedForward.TheMadArchivist.Views.Controls.ArchiveListControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel x:Name="ArchivesRootPanel" Spacing="8">
        <TextBlock
            x:Name="ArchivesTitleText"
            Text="Archives"
            Style="{ThemeResource SubtitleTextBlockStyle}"
            Margin="0,12,0,0" />

        <Grid
            x:Name="ArchivesInputGrid"
            ColumnSpacing="8">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox
                x:Name="NewArchivePathTextBox"
                PlaceholderText="Add archive path..."
                KeyDown="NewArchivePathTextBox_OnKeyDown"
                LostFocus="NewArchivePathTextBox_OnLostFocus"
                Text="{Binding ElementName=ControlRoot, Path=ViewModel.NewArchivePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Button
                x:Name="BrowseArchiveButton"
                Grid.Column="2"
                ToolTipService.ToolTip="Open Folder Selector"
                Click="BrowseArchiveButton_OnClick">
                <StackPanel Orientation="Horizontal" Spacing="6">                    
                    <SymbolIcon Symbol="Folder" />
                </StackPanel>
            </Button>            
            <Button
                x:Name="AddArchiveButton"
                Grid.Column="1"
                ToolTipService.ToolTip="Add Folder Path"
                IsEnabled="{Binding ElementName=ControlRoot, Path=ViewModel.IsAddEnabled}"
                Click="AddArchiveButton_OnClick">
                <StackPanel Orientation="Horizontal" Spacing="6">
                     <SymbolIcon Symbol="Add" />
                </StackPanel>
            </Button>
        </Grid>

        <ListView
            x:Name="ArchivesListView"
            ItemsSource="{Binding ElementName=ControlRoot, Path=ViewModel.Archives}"
            SelectedItem="{Binding ElementName=ControlRoot, Path=ViewModel.SelectedArchive, Mode=TwoWay}"
            MinHeight="120">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock
                            x:Name="ArchivePathText"
                            Text="{Binding}"
                            VerticalAlignment="Center"
                            TextTrimming="CharacterEllipsis" />
                        <Button
                            x:Name="RemoveArchiveItemButton"
                            Grid.Column="1"
                            Click="RemoveArchiveItemButton_OnClick">
                            <SymbolIcon Symbol="Delete" />
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </StackPanel>
</UserControl>
