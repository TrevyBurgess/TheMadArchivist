<UserControl
    x:Name="AboutControlRoot"
    x:Class="CyberFeedForward.TheMadArchivist.Views.Controls.AboutControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel
        x:Name="AboutRootPanel"
        Spacing="12"
        Padding="10,20">

        <TextBlock
            x:Name="AboutTitleText"
            Text="About"
            Style="{ThemeResource SubtitleTextBlockStyle}"
            Margin="0,12,0,0" />

        <TextBlock
            x:Name="AppNameText"
            Text="{Binding ElementName=AboutControlRoot, Path=ViewModel.Model.ApplicationName}"
            TextWrapping="WrapWholeWords" />

        <TextBlock
            x:Name="AppVersionText"
            Text="{Binding ElementName=AboutControlRoot, Path=ViewModel.Model.Version}"
            TextWrapping="WrapWholeWords" />

        <TextBlock
            x:Name="AppDescriptionText"
            Text="{Binding ElementName=AboutControlRoot, Path=ViewModel.Model.Description}"
            TextWrapping="WrapWholeWords" />

    </StackPanel>
</UserControl>
