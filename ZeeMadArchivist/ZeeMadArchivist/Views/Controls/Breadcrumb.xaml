<UserControl
    x:Name="ControlRoot"
    x:Class="CyberFeedForward.TheMadArchivist.Views.Controls.Breadcrumb"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid
        x:Name="BreadcrumbContentPanel"
        ColumnDefinitions="*,Auto">
        <Button
            x:Name="BreadcrumbTextButton"
            Click="BreadcrumbTextButton_OnClick"
            Background="Transparent"
            BorderThickness="0"
            Padding="4,2"
            HorizontalAlignment="Left">
            <TextBlock
                x:Name="BreadcrumbText"
                Text="{Binding ElementName=ControlRoot, Path=Text}"
                VerticalAlignment="Center" />
        </Button>
        <Button
            x:Name="BreadcrumbArrowButton"
            Grid.Column="1"
            Click="BreadcrumbButton_OnClick"
            Background="Transparent"
            BorderThickness="0"
            Padding="4,2">
            <SymbolIcon
                x:Name="BreadcrumbArrowIcon"
                Symbol="Forward"
                VerticalAlignment="Center" />
        </Button>
    </Grid>
</UserControl>
