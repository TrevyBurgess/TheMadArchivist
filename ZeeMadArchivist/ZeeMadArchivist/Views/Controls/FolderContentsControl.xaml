<UserControl
    x:Name="ControlRoot"
    x:Class="CyberFeedForward.TheMadArchivist.Views.Controls.FolderContentsControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:CyberFeedForward.TheMadArchivist.Converters"
    xmlns:models="using:CyberFeedForward.TheMadArchivist.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:IsFolderToSymbolConverter x:Key="IsFolderToSymbolConverter" />
        <converters:FolderIconBrushConverter x:Key="FolderIconBrushConverter" />
        <converters:ZeroCountToVisibilityConverter x:Key="ZeroCountToVisibilityConverter" />
    </UserControl.Resources>

    <Grid x:Name="RootGrid">
        <ListView
            x:Name="FolderContentsListView"
            ItemsSource="{Binding ElementName=ControlRoot, Path=Entries}"
            IsItemClickEnabled="True"
            ItemClick="FolderContentsListView_OnItemClick">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:FileSystemEntry">
                    <Grid
                        x:Name="FileSystemEntryRow"
                        ColumnDefinitions="Auto,*"
                        Padding="8,4">
                        <Grid
                            x:Name="EntryIconContainer"
                            Width="20"
                            Height="20"
                            VerticalAlignment="Center">
                            <FontIcon
                                x:Name="EntryIconBorder"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="18"
                                Glyph="&#xE838;"
                                Foreground="{Binding IsFolder, Converter={StaticResource FolderIconBrushConverter}, ConverterParameter=Border}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                            <FontIcon
                                x:Name="EntryIconFill"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="16"
                                Glyph="&#xE838;"
                                Foreground="{Binding IsFolder, Converter={StaticResource FolderIconBrushConverter}, ConverterParameter=Fill}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Grid>
                        <TextBlock
                            x:Name="EntryNameText"
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            Text="{Binding Name}"
                            VerticalAlignment="Center" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock
            x:Name="EmptyMessageText"
            Text="&lt;Empty&gt;"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Opacity="0.7"
            IsHitTestVisible="False"
            Visibility="{Binding ElementName=ControlRoot, Path=Entries.Count, Converter={StaticResource ZeroCountToVisibilityConverter}}" />
    </Grid>
</UserControl>
