<Page
    x:Class="CyberFeedForward.TheMadArchivist.Views.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="AboutRootGrid" Padding="16">
        <StackPanel x:Name="AboutStackPanel" Spacing="12">
            <TextBlock
                x:Name="AboutTitleText"
                Text="About"
                Style="{ThemeResource TitleTextBlockStyle}" />

            <TextBlock
                x:Name="AboutAppNameText"
                Text="The Mad Archivist"
                Opacity="0.9" />

            <TextBlock
                x:Name="AboutDescriptionText"
                Text="A tool to help organize and manage archives."
                Opacity="0.8" />
        </StackPanel>
    </Grid>
</Page>
