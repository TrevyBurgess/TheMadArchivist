<Page
    x:Class="CyberFeedForward.TheMadArchivist.Views.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewmodels="using:CyberFeedForward.TheMadArchivist.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <viewmodels:HomePageViewModel x:Key="ViewModel" />
    </Page.Resources>

    <Grid
        x:Name="HomeRootGrid"
        Padding="16"
        DataContext="{StaticResource ViewModel}">
        <StackPanel x:Name="HomeStackPanel" Spacing="12">
            <TextBlock
                x:Name="HomeTitleText"
                Text="{Binding Title}"
                Style="{ThemeResource TitleTextBlockStyle}" />
            <TextBlock
                x:Name="HomeDescriptionText"
                Text="{Binding Description}"
                Opacity="0.8" />
        </StackPanel>
    </Grid>
</Page>
