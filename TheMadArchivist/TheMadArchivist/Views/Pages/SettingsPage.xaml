<Page
    x:Class="TheMadArchivist.Views.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="SettingsRootGrid" Padding="16">
        <StackPanel x:Name="SettingsStackPanel" Spacing="12">
            <TextBlock
                x:Name="SettingsTitleText"
                Text="Settings"
                Style="{ThemeResource TitleTextBlockStyle}" />
            <TextBlock
                x:Name="SettingsDescriptionText"
                Text="Configure application preferences."
                Opacity="0.8" />

            <ToggleSwitch
                x:Name="DarkModeToggleSwitch"
                Header="Dark mode"
                Toggled="DarkModeToggleSwitch_OnToggled" />
        </StackPanel>
    </Grid>
</Page>
